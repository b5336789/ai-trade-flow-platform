#!/bin/bash
set -euo pipefail
exec > >(tee /var/log/user-data.log) 2>&1
echo "=== user-data start: $(date -u) ==="

# Docker + git
dnf install -y docker git
systemctl enable --now docker

# docker compose v2 plugin (arm64)
mkdir -p /usr/libexec/docker/cli-plugins
curl -fSL https://github.com/docker/compose/releases/download/v2.29.7/docker-compose-linux-aarch64 \
  -o /usr/libexec/docker/cli-plugins/docker-compose
chmod +x /usr/libexec/docker/cli-plugins/docker-compose

# 2GB swap so frontend image build does not OOM on a 2GB box
if [ ! -f /swapfile ]; then
  dd if=/dev/zero of=/swapfile bs=1M count=2048
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  echo '/swapfile none swap sw 0 0' >> /etc/fstab
fi

# App source
[ -d /opt/app/.git ] || git clone ${repo_url} /opt/app
cd /opt/app
git checkout ${branch}

# Environment for docker compose (env_file: .env). Frontend + API are served
# same-origin behind Caddy over HTTPS at the domain, so NEXT_PUBLIC_API_BASE_URL
# and CORS use https://<domain>.
cat > /opt/app/.env <<ENV
TRADING_MODE=paper
AI_PROVIDER=openrouter
AI_MODEL=openrouter/free
OPENROUTER_API_KEY=${openrouter_api_key}
API_TOKEN=${api_token}
NEXT_PUBLIC_API_TOKEN=${api_token}
NEXT_PUBLIC_API_BASE_URL=https://${domain}
API_CORS_ORIGINS=https://${domain}
ENV

# Caddy reverse proxy + auto-HTTPS. /api and /health -> backend, else -> frontend.
# Caddy gets a Let's Encrypt cert once the Route 53 A record (domain -> EIP) resolves.
cat > /opt/app/Caddyfile <<CADDY
${domain} {
    @api path /api/* /health
    reverse_proxy @api backend:8000
    reverse_proxy frontend:3000
}
CADDY

# systemd unit: bring containers up on EVERY boot (user-data only runs once).
cat > /etc/systemd/system/atf-demo.service <<UNIT
[Unit]
Description=AI Trade Flow demo (docker compose)
Requires=docker.service
After=docker.service network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/app
ExecStart=/usr/bin/docker compose -f docker-compose.demo.yml up -d
ExecStop=/usr/bin/docker compose -f docker-compose.demo.yml down

[Install]
WantedBy=multi-user.target
UNIT
systemctl daemon-reload
systemctl enable atf-demo

# First boot: build images + start
docker compose -f docker-compose.demo.yml up -d --build
echo "=== user-data done: $(date -u) ==="
