# ----------------------------------------------------------------------------
# ai-trade-flow-platform environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ----------------------------------------------------------------------------

# Trading mode: "paper" (simulated, safe default) or "live" (real orders).
TRADING_MODE=paper

# --- Anthropic / Claude (required for AI signal & explanation nodes) ---
ANTHROPIC_API_KEY=
# Default model for analysis/explanation. Sonnet is a cheaper option for
# high-frequency signal calls. See backend/app/config.py.
AI_MODEL=claude-opus-4-8

# AI provider: "anthropic" (Claude), "lmstudio" (local, OpenAI-compatible), or "openrouter" (cloud free)
AI_PROVIDER=anthropic
# Local LLM endpoint + key (only used when AI_PROVIDER=lmstudio). For LM Studio the key is a non-empty placeholder.
AI_BASE_URL=http://localhost:1234/v1
AI_LOCAL_API_KEY=lm-studio
# OpenRouter (cloud demo). Set AI_PROVIDER=openrouter, AI_MODEL=openrouter/free (free model router).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Retries on malformed/invalid structured output (lmstudio path). Local models need more than Claude.
AI_MAX_RETRIES=5

# --- Crypto exchange (ccxt / Binance) ---
# Leave blank to use public market data only (no live trading).
# SECURITY: create Binance API keys with WITHDRAWALS DISABLED and an IP allowlist. Prefer a
# read-only key for market data and a separate, locked-down (trade-only) key for orders.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# "true" routes live crypto orders to the Binance testnet sandbox.
BINANCE_TESTNET=true

# --- Taiwan stocks: 元大證券 (Yuanta) — later phase, not yet implemented ---
YUANTA_API_KEY=
YUANTA_API_SECRET=

# --- US stocks: Firstrade — later phase, unofficial API, not yet implemented ---
FIRSTRADE_USERNAME=
FIRSTRADE_PASSWORD=

# --- Transaction costs (M0.1) ---
# Applied to EVERY paper + backtest fill. Costs are ON by default — zero-cost return numbers
# overstate performance and bias the optimizer towards high-churn strategies. See
# backend/app/trading/costs.py.
# Crypto commission in basis points (1 bps = 0.01%). Default taker ~7.5 bps.
COST_CRYPTO_TAKER_BPS=7.5
COST_CRYPTO_MAKER_BPS=7.5
# 台股: 手續費率 0.1425% (買賣各一次) × 券商折讓係數;證交稅 0.3% (僅賣出).
COST_TW_FEE_RATE=0.001425
COST_TW_FEE_DISCOUNT=1.0
COST_TW_TAX_RATE=0.003
# 美股複委託: 費率 + 最低收費.
COST_US_FEE_RATE=0.0
COST_US_FEE_MIN=0.0
# Fixed slippage in basis points (buys fill higher, sells lower). 0 = no slippage.
COST_SLIPPAGE_BPS=0.0

# --- Backtest metrics (M0.3) ---
# Annual risk-free rate for Sharpe/Sortino (e.g. 0.02 = 2%). 0 = ignore.
BACKTEST_RISK_FREE_RATE=0.0

# --- Portfolio-level risk & FX (M0.6) ---
# All portfolio-level risk is judged in BASE_CURRENCY. FX_RATES is a comma-separated "CCY:rate"
# map giving each currency's value in the base currency (e.g. USD:31.5 => 1 USD = 31.5 TWD).
# Phase-0 static rates; M1.1 swaps in a live provider behind the same interface.
BASE_CURRENCY=TWD
FX_RATES=TWD:1.0,USD:31.5,USDT:31.5
# Cap on total open position market value (base currency). Buys past this are rejected.
MAX_TOTAL_EXPOSURE_VALUE=1000000
# Max intraday loss (day-start equity minus current equity, base currency). Breach HALTS trading
# (blocks new entries; exits still allowed) until manually resumed via POST /api/risk/resume.
MAX_DAILY_LOSS=100000
# Max orders placed per UTC day.
MAX_ORDERS_PER_DAY=50
# Config-level kill switch. When true, blocks new entries (exits still allowed). There is also a
# persisted runtime kill switch toggleable via POST /api/risk/kill-switch.
KILL_SWITCH=false

# --- Database (SQLite by default for local dev) ---
DATABASE_URL=sqlite:///./trade_flow.db

# --- Notifications (optional) ---
# Outbound webhook for order/signal alerts (e.g. Slack/Discord incoming webhook URL).
# Leave blank to only use the in-app notification feed.
NOTIFY_WEBHOOK_URL=

# --- API auth & CORS (M0.7) ---
# Shared bearer token required on every /api/* request (Authorization: Bearer <API_TOKEN>).
# GET /health stays public. If left BLANK, auth is DISABLED (open) for local dev/tests and the
# backend logs a loud warning — ALWAYS set a strong token for any networked/real deployment.
API_TOKEN=
# Comma-separated list of allowed CORS origins. Replaces the old wide-open "*".
API_CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Must equal API_TOKEN above when the backend has auth enabled. Sent as the bearer token from
# the browser. NOTE: NEXT_PUBLIC_* is exposed to the client, so this is only as private as the
# browser; rely on Binance key restrictions (above) and CORS for defence in depth.
NEXT_PUBLIC_API_TOKEN=

# --- AWS Deployment (GitHub Actions + Terraform) ---
# Values below are for GitHub Environment/Repository secrets used by the deploy workflow.
# Keep them out of local `.env` files.
# For API/auth entries, use the same values/secrets already defined above:
# - API_TOKEN
# - NEXT_PUBLIC_API_TOKEN (same value as API_TOKEN)
# - ANTHROPIC_API_KEY (optional; blank/omit disables AI features).

# AWS / Terraform
AWS_ACCOUNT_ID=
AWS_DEPLOY_ROLE_ARN=
TF_STATE_BUCKET=
TF_LOCK_TABLE=
